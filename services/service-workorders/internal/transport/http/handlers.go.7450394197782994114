	"time"
)

type workorder struct {
	ID                  string    `json:"id"`
	AppointmentID       string    `json:"appointment_id,omitempty"`
	ClientID            string    `json:"client_id"`
	OwnerID             string    `json:"owner_id"`
	VehicleVIN          string    `json:"vehicle_vin"`
	Assignee            string    `json:"assignee"`
	Status              string    `json:"status"`
	Deadline            string    `json:"deadline,omitempty"`
	SLAHours            int       `json:"sla_hours"`
	SLADeadline         string    `json:"sla_deadline"`
	SLABreached         bool      `json:"sla_breached"`
	RepeatVisit         bool      `json:"repeat_visit"`
	PreviousWorkorderID string    `json:"previous_workorder_id,omitempty"`
	QualityScore        int       `json:"quality_score,omitempty"`
	QualityComment      string    `json:"quality_comment,omitempty"`
	ReleasedAt          string    `json:"released_at,omitempty"`
	CreatedAt           time.Time `json:"created_at"`
	UpdatedAt           time.Time `json:"updated_at"`
}

type workorderSagaStep struct {
	Name   string `json:"name"`
	Status string `json:"status"`
	Note   string `json:"note,omitempty"`
}

type workorderAuditEvent struct {
	ID        string         `json:"id"`
	ActorID   string         `json:"actor_id"`
	Action    string         `json:"action"`
	ObjectID  string         `json:"object_id"`
	Before    map[string]any `json:"before,omitempty"`
	After     map[string]any `json:"after,omitempty"`
	TraceID   string         `json:"trace_id,omitempty"`
	CreatedAt time.Time      `json:"created_at"`
}

type workorderAccessContext struct {
	UserID string
	Roles  map[string]bool
}

type workorderNotification struct {
	ID         string    `json:"id"`
	WorkorderID string   `json:"workorder_id"`
	EventType  string    `json:"event_type"`
	Channel    string    `json:"channel"`
	Message    string    `json:"message"`
	CreatedAt  time.Time `json:"created_at"`
}

var workorderStore = struct {
	sync.RWMutex
	seq        int
	workorders []workorder
}{}

var workorderNotificationStore = struct {
	sync.RWMutex
	seq           int
	notifications []workorderNotification
}{}

var workorderAuditStore = struct {
	sync.RWMutex
	seq    int
	events []workorderAuditEvent
}{}

func RegisterHandlers(mux *http.ServeMux) {
	mux.HandleFunc("/healthz", healthHandler)
	mux.HandleFunc("/readyz", readyHandler)
	mux.HandleFunc("/workorders", workordersHandler)
	mux.HandleFunc("/workorders/", workordersStatusHandler)
	mux.HandleFunc("/audit/trail", workordersAuditTrailHandler)
	mux.HandleFunc("/notifications/outbox", workordersNotificationsHandler)
	mux.HandleFunc("/kpi/service", workordersKPIHandler)
}

func workordersHandler(w http.ResponseWriter, r *http.Request) {
	access := readWorkorderAccessContext(r)

	switch r.Method {
	case http.MethodGet:
		if !hasAnyWorkorderRole(access, "platform_admin", "service_manager", "service_advisor") {
			respondError(w, http.StatusForbidden, "rbac: role is not allowed for workorders read")
			return
		}

		workorderStore.RLock()
		defer workorderStore.RUnlock()
		statusFilter := strings.ToLower(strings.TrimSpace(r.URL.Query().Get("status")))
		overdueOnly := strings.EqualFold(strings.TrimSpace(r.URL.Query().Get("overdue")), "true")
		now := time.Now().UTC()
		filteredByQuery := make([]workorder, 0, len(workorderStore.workorders))
		for _, wo := range workorderStore.workorders {
			if statusFilter != "" && strings.ToLower(wo.Status) != statusFilter {
				continue
			}
			if overdueOnly && !isWorkorderOverdue(wo, now) {
				continue
			}
			filteredByQuery = append(filteredByQuery, wo)
		}

		if hasAnyWorkorderRole(access, "platform_admin", "service_manager") {
			respondJSON(w, http.StatusOK, filteredByQuery)
			return
		}

		filtered := make([]workorder, 0)
		for _, wo := range filteredByQuery {
			if wo.OwnerID == access.UserID {
				filtered = append(filtered, wo)
			}
		}
		respondJSON(w, http.StatusOK, filtered)
	case http.MethodPost:
		if !hasAnyWorkorderRole(access, "platform_admin", "service_manager", "service_advisor") {
			respondError(w, http.StatusForbidden, "rbac: role is not allowed for workorders create")
			return
		}

		var req struct {
			AppointmentID string `json:"appointment_id"`
			ClientID      string `json:"client_id"`
			OwnerID       string `json:"owner_id"`
			VehicleVIN    string `json:"vehicle_vin"`
			Assignee      string `json:"assignee"`
			Deadline      string `json:"deadline"`
			SLAHours      int    `json:"sla_hours"`
		}
		if err := decodeJSON(r, &req); err != nil {
			respondError(w, http.StatusBadRequest, err.Error())
			return
		}
		if req.ClientID == "" || req.VehicleVIN == "" {
			respondError(w, http.StatusBadRequest, "client_id and vehicle_vin are required")
			return
		}

		ownerID := req.OwnerID
		if ownerID == "" {
			ownerID = access.UserID
		}
		if ownerID == "" {
			respondError(w, http.StatusBadRequest, "owner_id is required (or provide X-User-ID)")
			return
		}
		if hasAnyWorkorderRole(access, "service_advisor") && !hasAnyWorkorderRole(access, "platform_admin", "service_manager") && ownerID != access.UserID {
			respondError(w, http.StatusForbidden, "rbac: service_advisor can create only own workorders")
			return
		}

		now := time.Now().UTC()
		slaHours := req.SLAHours
		if slaHours <= 0 {
			slaHours = 48
		}
		deadline := parseWorkorderDeadline(req.Deadline, now.Add(time.Duration(slaHours)*time.Hour))
		repeatVisit, previousID := detectRepeatVisit(strings.ToUpper(strings.TrimSpace(req.VehicleVIN)), now)

		workorderStore.Lock()
		defer workorderStore.Unlock()
		workorderStore.seq++
		entity := workorder{
			ID:                  fmt.Sprintf("wo-%05d", workorderStore.seq),
			AppointmentID:       req.AppointmentID,
			ClientID:            req.ClientID,
			OwnerID:             ownerID,
			VehicleVIN:          strings.ToUpper(strings.TrimSpace(req.VehicleVIN)),
			Assignee:            strings.TrimSpace(req.Assignee),
			Status:              "accepted",
			Deadline:            deadline.Format(time.RFC3339),
			SLAHours:            slaHours,
			SLADeadline:         deadline.Format(time.RFC3339),
			SLABreached:         now.After(deadline),
			RepeatVisit:         repeatVisit,
			PreviousWorkorderID: previousID,
			CreatedAt:           now,
			UpdatedAt:           now,
		}
		workorderStore.workorders = append(workorderStore.workorders, entity)
		appendWorkorderAuditEvent(
			defaultValue(access.UserID, "system"),
			"create_workorder",
			entity.ID,
			nil,
			snapshotWorkorder(entity),
			strings.TrimSpace(r.Header.Get("X-Trace-ID")),
		)
		appendWorkorderNotification(entity.ID, "WorkOrderOpened", "sms", fmt.Sprintf("Заказ-наряд %s принят в работу", entity.ID))
		if entity.RepeatVisit {
			appendWorkorderNotification(entity.ID, "RepeatVisitDetected", "internal", fmt.Sprintf("Повторное обращение по VIN %s (предыдущий WO: %s)", entity.VehicleVIN, entity.PreviousWorkorderID))
		}
		respondJSON(w, http.StatusCreated, entity)
	default:
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
	}
}

func workordersStatusHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}

	parts := strings.Split(strings.Trim(r.URL.Path, "/"), "/")
	if len(parts) != 3 || parts[0] != "workorders" {
		respondError(w, http.StatusNotFound, "route not found")
		return
	}

	workorderID := parts[1]
	action := parts[2]

	switch action {
	case "status":
		updateStatusHandler(w, r, workorderID)
	case "close":
		closeWorkorderSagaHandler(w, r, workorderID)
	case "quality":
		workorderQualityHandler(w, r, workorderID)
	default:
		respondError(w, http.StatusNotFound, "route not found")
	}
}

