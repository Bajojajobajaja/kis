func workordersKPIHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}

	workorderStore.RLock()
	defer workorderStore.RUnlock()
	now := time.Now().UTC()
	byStatus := map[string]int{}
	overdueCount := 0
	repeatCount := 0
	closedCount := 0
	closedOnTime := 0
	qualityCount := 0
	qualitySum := 0
	cycleHoursTotal := 0.0

	for _, entity := range workorderStore.workorders {
		byStatus[entity.Status]++
		if isWorkorderOverdue(entity, now) {
			overdueCount++
		}
		if entity.RepeatVisit {
			repeatCount++
		}
		if entity.QualityScore > 0 {
			qualityCount++
			qualitySum += entity.QualityScore
		}
		if entity.Status == "closed" {
			closedCount++
			if !entity.SLABreached {
				closedOnTime++
			}
			cycleHoursTotal += now.Sub(entity.CreatedAt).Hours()
		}
	}

	keys := make([]string, 0, len(byStatus))
	for key := range byStatus {
		keys = append(keys, key)
	}
	sort.Strings(keys)
	orderedStatus := make([]map[string]any, 0, len(keys))
	for _, key := range keys {
		orderedStatus = append(orderedStatus, map[string]any{
			"status": key,
			"count":  byStatus[key],
		})
	}

	avgCycleHours := 0.0
	if closedCount > 0 {
		avgCycleHours = round2(cycleHoursTotal / float64(closedCount))
	}
	repeatRate := 0.0
	if len(workorderStore.workorders) > 0 {
		repeatRate = round2(float64(repeatCount) * 100 / float64(len(workorderStore.workorders)))
	}
	onTimeRate := 0.0
	if closedCount > 0 {
		onTimeRate = round2(float64(closedOnTime) * 100 / float64(closedCount))
	}
	avgQuality := 0.0
	if qualityCount > 0 {
		avgQuality = round2(float64(qualitySum) / float64(qualityCount))
	}

	respondJSON(w, http.StatusOK, map[string]any{
		"generated_at":            now.Format(time.RFC3339),
		"total_workorders":        len(workorderStore.workorders),
		"overdue_workorders":      overdueCount,
		"closed_workorders":       closedCount,
		"average_cycle_hours":     avgCycleHours,
		"repeat_visit_rate_pct":   repeatRate,
		"on_time_close_rate_pct":  onTimeRate,
		"average_quality_score":   avgQuality,
		"status_breakdown":        orderedStatus,
	})
}

func updateStatusHandler(w http.ResponseWriter, r *http.Request, workorderID string) {
	var req struct {
		Status string `json:"status"`
	}
	if err := decodeJSON(r, &req); err != nil {
		respondError(w, http.StatusBadRequest, err.Error())
		return
	}
	if req.Status == "" {
		respondError(w, http.StatusBadRequest, "status is required")
		return
	}
	nextStatus := strings.ToLower(strings.TrimSpace(req.Status))
	if nextStatus == "" {
		respondError(w, http.StatusBadRequest, "status is required")
		return
	}

	workorderStore.Lock()
	defer workorderStore.Unlock()

	index := findWorkorderIndex(workorderID)
	if index < 0 {
		respondError(w, http.StatusNotFound, "workorder not found")
		return
	}
	if !canWriteWorkorder(readWorkorderAccessContext(r), workorderStore.workorders[index]) {
		respondError(w, http.StatusForbidden, "rbac: endpoint/object access denied")
		return
	}

	entity := workorderStore.workorders[index]
	if !isAllowedWorkorderTransition(entity.Status, nextStatus) {
		respondError(w, http.StatusConflict, "invalid status transition")
		return
	}

	before := snapshotWorkorder(entity)
	now := time.Now().UTC()
	entity.Status = nextStatus
	if nextStatus == "released" && entity.ReleasedAt == "" {
		entity.ReleasedAt = now.Format(time.RFC3339)
	}
	entity.SLABreached = isWorkorderOverdue(entity, now)
	entity.UpdatedAt = now
	workorderStore.workorders[index] = entity

	appendWorkorderAuditEvent(
		defaultValue(readWorkorderAccessContext(r).UserID, "system"),
		"update_status",
		entity.ID,
		before,
		snapshotWorkorder(entity),
		strings.TrimSpace(r.Header.Get("X-Trace-ID")),
	)
	appendWorkorderNotification(entity.ID, "WorkorderStatusChanged", "sms", fmt.Sprintf("WO %s: статус %s", entity.ID, entity.Status))
	if entity.Status == "ready" {
		appendWorkorderNotification(entity.ID, "VehicleReady", "sms", fmt.Sprintf("WO %s: автомобиль готов к выдаче", entity.ID))
	}
	respondJSON(w, http.StatusOK, entity)
}

func closeWorkorderSagaHandler(w http.ResponseWriter, r *http.Request, workorderID string) {
	var req struct {
		SimulatePartsFailure   bool `json:"simulate_parts_failure"`
		SimulateBillingFailure bool `json:"simulate_billing_failure"`
	}
	if err := decodeJSON(r, &req); err != nil {
		respondError(w, http.StatusBadRequest, err.Error())
		return
	}

	workorderStore.Lock()
	defer workorderStore.Unlock()

	index := findWorkorderIndex(workorderID)
	if index < 0 {
		respondError(w, http.StatusNotFound, "workorder not found")
		return
	}
	if !canWriteWorkorder(readWorkorderAccessContext(r), workorderStore.workorders[index]) {
		respondError(w, http.StatusForbidden, "rbac: endpoint/object access denied")
		return
	}

	entity := workorderStore.workorders[index]
	if entity.Status != "ready" && entity.Status != "released" {
		respondError(w, http.StatusConflict, "workorder can be closed only from ready/released")
		return
	}
	before := snapshotWorkorder(entity)
	steps := make([]workorderSagaStep, 0, 4)
	now := time.Now().UTC()

	if req.SimulatePartsFailure {
		steps = append(steps, workorderSagaStep{Name: "parts.consume", Status: "failed", Note: "stock unavailable"})
		entity.Status = "close_failed"
		entity.UpdatedAt = now
		workorderStore.workorders[index] = entity
		appendWorkorderAuditEvent(
			defaultValue(readWorkorderAccessContext(r).UserID, "system"),
			"close",
			entity.ID,
			before,
			snapshotWorkorder(entity),
			strings.TrimSpace(r.Header.Get("X-Trace-ID")),
		)
		respondJSON(w, http.StatusOK, map[string]any{
			"saga":      "workorder-close",
			"result":    "failed",
			"steps":     steps,
			"workorder": entity,
		})
		return
	}

	steps = append(steps, workorderSagaStep{Name: "parts.consume", Status: "completed"})
	if req.SimulateBillingFailure {
		steps = append(steps, workorderSagaStep{Name: "billing.invoice", Status: "failed", Note: "billing timeout"})
		steps = append(steps, workorderSagaStep{Name: "parts.release", Status: "completed"})
		entity.Status = "compensated"
		entity.UpdatedAt = now
		workorderStore.workorders[index] = entity
		appendWorkorderAuditEvent(
			defaultValue(readWorkorderAccessContext(r).UserID, "system"),
			"close",
			entity.ID,
			before,
			snapshotWorkorder(entity),
			strings.TrimSpace(r.Header.Get("X-Trace-ID")),
		)
		respondJSON(w, http.StatusOK, map[string]any{
			"saga":      "workorder-close",
			"result":    "compensated",
			"steps":     steps,
			"workorder": entity,
		})
		return
	}

	steps = append(steps, workorderSagaStep{Name: "billing.invoice", Status: "completed"})
	steps = append(steps, workorderSagaStep{Name: "workorder.close", Status: "completed"})
	entity.Status = "closed"
	if entity.ReleasedAt == "" {
		entity.ReleasedAt = now.Format(time.RFC3339)
	}
	entity.SLABreached = isWorkorderOverdue(entity, now)
	entity.UpdatedAt = now
	workorderStore.workorders[index] = entity
	appendWorkorderAuditEvent(
		defaultValue(readWorkorderAccessContext(r).UserID, "system"),
		"close",
		entity.ID,
		before,
		snapshotWorkorder(entity),
		strings.TrimSpace(r.Header.Get("X-Trace-ID")),
	)
	appendWorkorderNotification(entity.ID, "WorkOrderCompleted", "sms", fmt.Sprintf("WO %s закрыт", entity.ID))
	respondJSON(w, http.StatusOK, map[string]any{
		"saga":      "workorder-close",
		"result":    "completed",
		"steps":     steps,
		"workorder": entity,
	})
}

func workorderQualityHandler(w http.ResponseWriter, r *http.Request, workorderID string) {
	if r.Method != http.MethodPost {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}
	var req struct {
		Score   int    `json:"score"`
		Comment string `json:"comment"`
	}
	if err := decodeJSON(r, &req); err != nil {
		respondError(w, http.StatusBadRequest, err.Error())
		return
	}
	if req.Score < 1 || req.Score > 5 {
		respondError(w, http.StatusBadRequest, "score must be between 1 and 5")
		return
	}

	workorderStore.Lock()
	defer workorderStore.Unlock()
	index := findWorkorderIndex(workorderID)
	if index < 0 {
		respondError(w, http.StatusNotFound, "workorder not found")
		return
	}
	if !canWriteWorkorder(readWorkorderAccessContext(r), workorderStore.workorders[index]) {
		respondError(w, http.StatusForbidden, "rbac: endpoint/object access denied")
		return
	}

	entity := workorderStore.workorders[index]
	before := snapshotWorkorder(entity)
	entity.QualityScore = req.Score
	entity.QualityComment = strings.TrimSpace(req.Comment)
	entity.UpdatedAt = time.Now().UTC()
	workorderStore.workorders[index] = entity

	appendWorkorderAuditEvent(
		defaultValue(readWorkorderAccessContext(r).UserID, "system"),
		"update_quality",
		entity.ID,
		before,
		snapshotWorkorder(entity),
		strings.TrimSpace(r.Header.Get("X-Trace-ID")),
	)
	appendWorkorderNotification(entity.ID, "QualityFeedbackRecorded", "internal", fmt.Sprintf("WO %s: оценка качества %d/5", entity.ID, entity.QualityScore))
	respondJSON(w, http.StatusOK, entity)
}

func canWriteWorkorder(access workorderAccessContext, entity workorder) bool {
	if hasAnyWorkorderRole(access, "platform_admin", "service_manager") {
		return true
	}
	if hasAnyWorkorderRole(access, "service_advisor") {
		return access.UserID != "" && access.UserID == entity.OwnerID
	}
	return false
}

func readWorkorderAccessContext(r *http.Request) workorderAccessContext {
	userID := strings.TrimSpace(r.Header.Get("X-User-ID"))
	rolesRaw := r.Header.Get("X-Role")
	if rolesRaw == "" {
		rolesRaw = r.Header.Get("X-Roles")
	}

	roles := map[string]bool{}
	for _, raw := range strings.Split(rolesRaw, ",") {
		role := strings.TrimSpace(strings.ToLower(raw))
		if role != "" {
			roles[role] = true
		}
	}
	return workorderAccessContext{
		UserID: userID,
		Roles:  roles,
	}
}

func hasAnyWorkorderRole(access workorderAccessContext, allowed ...string) bool {
	for _, role := range allowed {
		if access.Roles[strings.ToLower(role)] {
			return true
		}
	}
	return false
}

func findWorkorderIndex(id string) int {
	for i := range workorderStore.workorders {
		if workorderStore.workorders[i].ID == id {
			return i
		}
	}
	return -1
}

func appendWorkorderNotification(workorderID, eventType, channel, message string) {
	workorderNotificationStore.Lock()
	defer workorderNotificationStore.Unlock()
	workorderNotificationStore.seq++
	workorderNotificationStore.notifications = append(workorderNotificationStore.notifications, workorderNotification{
		ID:          fmt.Sprintf("won-%06d", workorderNotificationStore.seq),
		WorkorderID: workorderID,
		EventType:   eventType,
		Channel:     channel,
		Message:     message,
		CreatedAt:   time.Now().UTC(),
	})
}

func appendWorkorderAuditEvent(actorID, action, objectID string, before, after map[string]any, traceID string) {
	workorderAuditStore.Lock()
	defer workorderAuditStore.Unlock()
	workorderAuditStore.seq++
	workorderAuditStore.events = append(workorderAuditStore.events, workorderAuditEvent{
		ID:        fmt.Sprintf("woa-%06d", workorderAuditStore.seq),
		ActorID:   actorID,
		Action:    action,
		ObjectID:  objectID,
		Before:    before,
		After:     after,
		TraceID:   traceID,
		CreatedAt: time.Now().UTC(),
	})
}

func snapshotWorkorder(entity workorder) map[string]any {
	raw, err := json.Marshal(entity)
	if err != nil {
		return map[string]any{}
	}

	out := map[string]any{}
	if err := json.Unmarshal(raw, &out); err != nil {
		return map[string]any{}
	}
	return out
}

func parseWorkorderDeadline(raw string, fallback time.Time) time.Time {
	value := strings.TrimSpace(raw)
	if value == "" {
		return fallback
	}
	parsed, err := time.Parse(time.RFC3339, value)
	if err != nil {
		return fallback
	}
	return parsed
}

func isWorkorderOverdue(entity workorder, now time.Time) bool {
	if entity.Status == "closed" || entity.Status == "released" {
		return entity.SLABreached
	}
	parsed, err := time.Parse(time.RFC3339, entity.SLADeadline)
	if err != nil {
		return false
	}
	return now.After(parsed)
}

func detectRepeatVisit(vehicleVIN string, now time.Time) (bool, string) {
	if vehicleVIN == "" {
		return false, ""
	}
	workorderStore.RLock()
	defer workorderStore.RUnlock()

	var latest *workorder
	for i := range workorderStore.workorders {
		entity := workorderStore.workorders[i]
		if strings.ToUpper(strings.TrimSpace(entity.VehicleVIN)) != vehicleVIN {
			continue
		}
		if entity.Status != "released" && entity.Status != "closed" {
			continue
		}
		updated := entity.UpdatedAt
		if latest == nil || updated.After(latest.UpdatedAt) {
			copy := entity
			latest = &copy
		}
	}
	if latest == nil {
		return false, ""
	}
	if now.Sub(latest.UpdatedAt) <= 30*24*time.Hour {
		return true, latest.ID
	}
	return false, ""
}

func isAllowedWorkorderTransition(from, to string) bool {
	from = strings.ToLower(strings.TrimSpace(from))
	to = strings.ToLower(strings.TrimSpace(to))
	if from == "" || to == "" {
		return false
	}
	if from == to {
		return true
	}
	allowed := map[string]map[string]bool{
		"accepted":      {"diagnostics": true, "in_progress": true, "waiting_parts": true},
		"diagnostics":   {"in_progress": true, "waiting_parts": true},
		"in_progress":   {"waiting_parts": true, "ready": true},
		"waiting_parts": {"in_progress": true, "ready": true},
		"ready":         {"released": true, "closed": true},
		"released":      {"closed": true},
		"close_failed":  {"in_progress": true, "waiting_parts": true},
		"compensated":   {"in_progress": true, "ready": true},
	}
	return allowed[from][to]
}

func defaultValue(value, fallback string) string {
	if value == "" {
		return fallback
	}
	return value
}

func round2(value float64) float64 {
	return math.Round(value*100) / 100
}

