func appendBIEventLocked(eventType, entityID string, payload map[string]any) {
	biStore.eventSeq++
	biStore.events = append(biStore.events, biEvent{
		ID:        fmt.Sprintf("bie-%05d", biStore.eventSeq),
		EventType: eventType,
		EntityID:  entityID,
		Payload:   payload,
		CreatedAt: time.Now().UTC(),
	})
}

func findSLOIndexLocked(id string) int {
	for i := range biStore.slos {
		if biStore.slos[i].ID == id {
			return i
		}
	}
	return -1
}

