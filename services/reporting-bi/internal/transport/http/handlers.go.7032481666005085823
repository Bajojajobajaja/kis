func RegisterHandlers(mux *http.ServeMux) {
	mux.HandleFunc("/healthz", healthHandler)
	mux.HandleFunc("/readyz", readyHandler)
	mux.HandleFunc("/bi/kpis", kpisHandler)
	mux.HandleFunc("/bi/observability", observabilityHandler)
	mux.HandleFunc("/bi/slo", sloHandler)
	mux.HandleFunc("/bi/slo/", sloStatusHandler)
	mux.HandleFunc("/bi/alerts", alertsHandler)
	mux.HandleFunc("/bi/alerts/", alertTriggerHandler)
	mux.HandleFunc("/bi/backups", backupsHandler)
	mux.HandleFunc("/bi/backups/", backupRestoreHandler)
	mux.HandleFunc("/bi/runbooks", runbooksHandler)
	mux.HandleFunc("/bi/delivery", deliveryHandler)
	mux.HandleFunc("/bi/delivery/", deliveryStatusHandler)
	mux.HandleFunc("/bi/finops", finopsHandler)
	mux.HandleFunc("/events", eventsHandler)
}

func kpisHandler(w http.ResponseWriter, r *http.Request) {
	switch r.Method {
	case http.MethodGet:
		biStore.RLock()
		defer biStore.RUnlock()
		respondJSON(w, http.StatusOK, biStore.kpis)
	case http.MethodPost:
		var req struct {
			Name   string  `json:"name"`
			Domain string  `json:"domain"`
			Value  float64 `json:"value"`
			Unit   string  `json:"unit"`
		}
		if err := decodeJSON(r, &req); err != nil {
			respondError(w, http.StatusBadRequest, err.Error())
			return
		}
		if strings.TrimSpace(req.Name) == "" {
			respondError(w, http.StatusBadRequest, "name is required")
			return
		}
		now := time.Now().UTC()
		biStore.Lock()
		defer biStore.Unlock()
		biStore.kpiSeq++
		entity := kpiSnapshot{
			ID:        fmt.Sprintf("kpi-%04d", biStore.kpiSeq),
			Name:      strings.TrimSpace(req.Name),
			Domain:    defaultValue(strings.TrimSpace(req.Domain), "platform"),
			Value:     req.Value,
			Unit:      defaultValue(strings.TrimSpace(req.Unit), "count"),
			UpdatedAt: now,
		}
		biStore.kpis = append(biStore.kpis, entity)
		appendBIEventLocked("BIKPIUpdated", entity.ID, map[string]any{"name": entity.Name, "value": entity.Value})
		respondJSON(w, http.StatusCreated, entity)
	default:
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
	}
}

func observabilityHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}
	biStore.RLock()
	defer biStore.RUnlock()
	requests := 0
	latencySum := 0.0
	errorRate := 0.0
	for _, metric := range biStore.finops {
		requests += metric.Requests
		latencySum += metric.LatencyP95
		errorRate += metric.ErrorRate
	}
	avgLatency := 0.0
	avgError := 0.0
	if len(biStore.finops) > 0 {
		avgLatency = latencySum / float64(len(biStore.finops))
		avgError = errorRate / float64(len(biStore.finops))
	}
	respondJSON(w, http.StatusOK, map[string]any{
		"services":              len(biStore.finops),
		"requests_total":        requests,
		"latency_p95_avg_ms":    round2(avgLatency),
		"error_rate_avg_pct":    round2(avgError),
		"trace_span_rate":       0.94,
		"log_ingestion_per_min": requests / 60,
	})
}

func sloHandler(w http.ResponseWriter, r *http.Request) {
	switch r.Method {
	case http.MethodGet:
		biStore.RLock()
		defer biStore.RUnlock()
		respondJSON(w, http.StatusOK, biStore.slos)
	case http.MethodPost:
		var req struct {
			Name      string  `json:"name"`
			Service   string  `json:"service"`
			Window    string  `json:"window"`
			TargetPct float64 `json:"target_pct"`
		}
		if err := decodeJSON(r, &req); err != nil {
			respondError(w, http.StatusBadRequest, err.Error())
			return
		}
		if strings.TrimSpace(req.Name) == "" || strings.TrimSpace(req.Service) == "" {
			respondError(w, http.StatusBadRequest, "name and service are required")
			return
		}
		if req.TargetPct <= 0 || req.TargetPct > 100 {
			respondError(w, http.StatusBadRequest, "target_pct must be in (0,100]")
			return
		}
		now := time.Now().UTC()
		biStore.Lock()
		defer biStore.Unlock()
		biStore.sloSeq++
		entity := sloDefinition{
			ID:             fmt.Sprintf("slo-%04d", biStore.sloSeq),
			Name:           strings.TrimSpace(req.Name),
			Service:        strings.TrimSpace(req.Service),
			Window:         defaultValue(strings.TrimSpace(req.Window), "30d"),
			TargetPct:      req.TargetPct,
			ErrorBudgetPct: round2(100 - req.TargetPct),
			Status:         "healthy",
			UpdatedAt:      now,
		}
		biStore.slos = append(biStore.slos, entity)
		appendBIEventLocked("SLOCreated", entity.ID, map[string]any{"service": entity.Service, "target_pct": entity.TargetPct})
		respondJSON(w, http.StatusCreated, entity)
	default:
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
	}
}

func sloStatusHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}
	parts := strings.Split(strings.Trim(r.URL.Path, "/"), "/")
	if len(parts) != 4 || parts[0] != "bi" || parts[1] != "slo" || parts[3] != "status" {
		respondError(w, http.StatusNotFound, "route not found")
		return
	}
	sloID := parts[2]
	var req struct {
		Status string `json:"status"`
	}
	if err := decodeJSON(r, &req); err != nil {
		respondError(w, http.StatusBadRequest, err.Error())
		return
	}
	status := strings.ToLower(strings.TrimSpace(req.Status))
	if status != "healthy" && status != "degraded" && status != "breached" {
		respondError(w, http.StatusBadRequest, "unsupported status")
		return
	}
	biStore.Lock()
	defer biStore.Unlock()
	index := findSLOIndexLocked(sloID)
	if index < 0 {
		respondError(w, http.StatusNotFound, "slo not found")
		return
	}
	biStore.slos[index].Status = status
	biStore.slos[index].UpdatedAt = time.Now().UTC()
	appendBIEventLocked("SLOStatusChanged", sloID, map[string]any{"status": status})
	respondJSON(w, http.StatusOK, biStore.slos[index])
}

