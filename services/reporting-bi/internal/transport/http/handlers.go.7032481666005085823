func deliveryStatusHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}
	parts := strings.Split(strings.Trim(r.URL.Path, "/"), "/")
	if len(parts) != 4 || parts[0] != "bi" || parts[1] != "delivery" || parts[3] != "status" {
		respondError(w, http.StatusNotFound, "route not found")
		return
	}
	deliveryID := parts[2]
	var req struct {
		Status string `json:"status"`
	}
	if err := decodeJSON(r, &req); err != nil {
		respondError(w, http.StatusBadRequest, err.Error())
		return
	}
	status := strings.ToLower(strings.TrimSpace(req.Status))
	if status != "planned" && status != "rolling_out" && status != "active" && status != "rolled_back" && status != "failed" {
		respondError(w, http.StatusBadRequest, "unsupported status")
		return
	}
	biStore.Lock()
	defer biStore.Unlock()
	index := findDeliveryIndexLocked(deliveryID)
	if index < 0 {
		respondError(w, http.StatusNotFound, "delivery plan not found")
		return
	}
	biStore.deliveries[index].Status = status
	biStore.deliveries[index].UpdatedAt = time.Now().UTC()
	eventType := "DeliveryStatusChanged"
	if status == "rolled_back" {
		eventType = "DeliveryRolledBack"
	}
	appendBIEventLocked(eventType, deliveryID, map[string]any{"status": status})
	respondJSON(w, http.StatusOK, biStore.deliveries[index])
}

func finopsHandler(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		respondError(w, http.StatusMethodNotAllowed, "method not allowed")
		return
	}
	biStore.RLock()
	defer biStore.RUnlock()
	totalCost := 0.0
	totalReq := 0
	weightedLatency := 0.0
	weightedErr := 0.0
	for _, metric := range biStore.finops {
		totalCost += metric.CostUSD
		totalReq += metric.Requests
		weightedLatency += metric.LatencyP95 * float64(metric.Requests)
		weightedErr += metric.ErrorRate * float64(metric.Requests)
	}
	latency := 0.0
	errRate := 0.0
	if totalReq > 0 {
		latency = weightedLatency / float64(totalReq)
		errRate = weightedErr / float64(totalReq)
	}
	respondJSON(w, http.StatusOK, map[string]any{
		"services":             len(biStore.finops),
		"total_cost_usd":       round2(totalCost),
		"requests_total":       totalReq,
		"latency_p95_weighted": round2(latency),
		"error_rate_weighted":  round2(errRate),
		"details":              biStore.finops,
	})
}

